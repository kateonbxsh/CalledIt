rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/adminConfig/$(request.auth.uid));
    }

    function username() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? me().data.username
        : '';
    }

    function canReadBet() {
      return signedIn() && (
        !resource.data.keys().hasAny(['visibility']) ||
        (resource.data.visibility == 'public' && notMasked()) ||
        resource.data.creatorId == request.auth.uid ||
        (username() in resource.data.invitedUsernames && notMasked()) ||
        canReadGroupLinkedResource() ||
        isAdmin()
      );
    }

    function canReadBetById(betId) {
      return signedIn()
        && exists(/databases/$(database)/documents/bets/$(betId))
        && (
          (
            get(/databases/$(database)/documents/bets/$(betId)).data.visibility == 'public' &&
            (
              !get(/databases/$(database)/documents/bets/$(betId)).data.keys().hasAny(['maskedUsernames']) ||
              !(username() in get(/databases/$(database)/documents/bets/$(betId)).data.maskedUsernames)
            )
          ) ||
          get(/databases/$(database)/documents/bets/$(betId)).data.creatorId == request.auth.uid ||
          (
            username() in get(/databases/$(database)/documents/bets/$(betId)).data.invitedUsernames &&
            (
              !get(/databases/$(database)/documents/bets/$(betId)).data.keys().hasAny(['maskedUsernames']) ||
              !(username() in get(/databases/$(database)/documents/bets/$(betId)).data.maskedUsernames)
            )
          ) ||
          isAdmin()
        );
    }

    function canReadChallenge() {
      return signedIn() && (
        resource.data.visibility == 'public' ||
        resource.data.creatorId == request.auth.uid ||
        username() in resource.data.invitedUsernames ||
        canReadGroupLinkedResource() ||
        isAdmin()
      );
    }

    function canReadGroupLinkedResource() {
      return signedIn()
        && resource.data.keys().hasAny(['groupId'])
        && resource.data.groupId != null
        && notMasked()
        && exists(/databases/$(database)/documents/friendGroups/$(resource.data.groupId))
        && (
          get(/databases/$(database)/documents/friendGroups/$(resource.data.groupId)).data.creatorId == request.auth.uid ||
          request.auth.uid in get(/databases/$(database)/documents/friendGroups/$(resource.data.groupId)).data.memberUids
        );
    }

    function notMasked() {
      return !resource.data.keys().hasAny(['maskedUsernames']) ||
        !(username() in resource.data.maskedUsernames);
    }

    // Any signed-in user can write resolution fields — the allowlist is the security boundary.
    // Note: canReadBet() is deliberately NOT called here to avoid a cross-doc get() on a
    // document that may also be written in the same transaction commit (causes 403 in Firestore).
    function canResolveBet() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            'status',
            'resolution',
            'resolvedAt',
            'resolvedBy',
            'chanceSummary',
            'options',
            'predictionCount',
            'totalCoinsStaked',
            'updatedAt'
          ]);
    }

    function canApplyResolutionToUser() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['coinBalance', 'rating', 'rank', 'stats', 'pendingSpicyForecasts', 'updatedAt']);
    }

    function canApplyPredictionResult() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            'status',
            'correct',
            'coinDelta',
            'ratingDelta',
            'poolCoinProfit',
            'mintedCoinReward',
            'timingMultiplier',
            'spicyForecastBonus',
            'resolvedAt',
            'winningOptionId'
          ]);
    }

    function canEditBetMetadata() {
      return signedIn()
        && resource.data.creatorId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['title', 'description', 'category', 'deadline', 'imageUrl', 'visibility', 'groupId', 'status', 'invitedUsernames', 'maskedUsernames', 'allowMultipleChoices', 'allowMultipleOutcomes', 'updatedAt'])
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['status']) ||
          request.resource.data.status in ['open', 'locked']
        );
    }

    function canSyncGroupInvites() {
      return signedIn()
        && resource.data.groupId != null
        && exists(/databases/$(database)/documents/friendGroups/$(resource.data.groupId))
        && get(/databases/$(database)/documents/friendGroups/$(resource.data.groupId)).data.creatorId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['invitedUsernames', 'maskedUsernames', 'updatedAt']);
    }

    function canSyncChallengeGroupInvites() {
      return signedIn()
        && resource.data.groupId != null
        && exists(/databases/$(database)/documents/friendGroups/$(resource.data.groupId))
        && get(/databases/$(database)/documents/friendGroups/$(resource.data.groupId)).data.creatorId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['invitedUsernames', 'updatedAt']);
    }

    match /usernames/{name} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(name));
      allow update: if false;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        (
          request.auth.uid == userId
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly([
              'displayName',
              'photoURL',
              'bio',
              'username',
              'updatedAt',
              'lastRefillAt',
              'coinBalance',
              'lastDailyForecastAt',
              'pendingSpicyForecasts',
              'lastWheelSpinAt',
              'stats'
            ])
        ) ||
        canApplyResolutionToUser()
      );
      allow delete: if false;
    }

    match /bets/{betId} {
      allow read: if canReadBet();
      allow create: if signedIn()
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if isAdmin() || canResolveBet() || canEditBetMetadata() || canSyncGroupInvites();
      allow delete: if signedIn() && resource.data.creatorId == request.auth.uid;
    }

    match /predictions/{predictionId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.stake >= 10;
      allow update: if canApplyPredictionResult() || (
        signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            'optionId',
            'optionIds',
            'stake',
            'userBalanceAtBetTime',
            'displayedChanceAtBetTime',
            'userRating',
            'originalOptionId',
            'originalStake',
            'originalChanceAtBetTime',
            'lastChangedAt',
            'revisionCount',
            'changeFeesPaid',
            'lastChangeFee',
            'scorePrediction',
            'numericGuess',
            'dateGuess',
            'customOptionLabel'
          ])
      );
      allow delete: if false;
    }

    match /users/{userId}/notificationTokens/{tokenId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['token', 'enabled', 'userAgent', 'createdAt', 'updatedAt', 'disabledAt']);
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/dailyBonuses/{dateKey} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['dateKey', 'bonuses', 'totalClaimed', 'updatedAt']);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && (
        request.auth.uid in resource.data.targetUids ||
        resource.data.actorUid == request.auth.uid ||
        isAdmin()
      );
      allow create: if signedIn()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.targetUids is list
        && request.resource.data.keys().hasOnly([
          'type',
          'actorUid',
          'actorUsername',
          'actorDisplayName',
          'targetUids',
          'title',
          'body',
          'url',
          'readBy',
          'sentAt',
          'createdAt'
        ]);
      allow update: if signedIn()
        && request.auth.uid in resource.data.targetUids
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy']);
      allow delete: if false;
    }

    match /predictionEvents/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /chanceSnapshots/{snapshotId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /comments/{commentId} {
      allow read: if canReadBetById(resource.data.betId);
      allow create: if signedIn()
        && canReadBetById(request.resource.data.betId)
        && request.resource.data.keys().hasOnly([
          'betId',
          'userId',
          'username',
          'displayName',
          'photoURL',
          'body',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username == username()
        && request.resource.data.displayName == me().data.displayName
        && (
          (me().data.keys().hasAny(['photoURL']) && request.resource.data.photoURL == me().data.photoURL) ||
          (!me().data.keys().hasAny(['photoURL']) && request.resource.data.photoURL == null)
        )
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1000
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if false;
      allow delete: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    match /activity/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /rewardClaims/{claimId} {
      allow get: if signedIn() && (
        claimId.matches('^' + request.auth.uid + '_.*') ||
        resource.data.userId == request.auth.uid
      );
      allow list: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && claimId.matches('^' + request.auth.uid + '_.*');
      allow update, delete: if false;
    }

    match /challenges/{challengeId} {
      allow read: if canReadChallenge();
      allow create: if signedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.creatorId == request.auth.uid ||
        request.resource.data.completerId == request.auth.uid ||
        canSyncChallengeGroupInvites()
      );
      allow delete: if false;
    }

    match /adminConfig/{uid} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /friendGroups/{groupId} {
      allow read: if signedIn() && (
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.memberUids
      );
      allow create: if signedIn()
        && request.resource.data.creatorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.creatorId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['name', 'memberUsernames', 'memberUids', 'updatedAt']);
      allow delete: if signedIn()
        && resource.data.creatorId == request.auth.uid;
    }
  }
}
