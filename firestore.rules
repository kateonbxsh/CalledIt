rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/adminConfig/$(request.auth.uid));
    }

    function username() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? me().data.username
        : '';
    }

    function canReadBet() {
      return signedIn() && (
        resource.data.visibility == 'public' ||
        resource.data.creatorId == request.auth.uid ||
        username() in resource.data.invitedUsernames ||
        isAdmin()
      );
    }

    function canReadBetById(betId) {
      return signedIn()
        && exists(/databases/$(database)/documents/bets/$(betId))
        && (
          get(/databases/$(database)/documents/bets/$(betId)).data.visibility == 'public' ||
          get(/databases/$(database)/documents/bets/$(betId)).data.creatorId == request.auth.uid ||
          username() in get(/databases/$(database)/documents/bets/$(betId)).data.invitedUsernames ||
          isAdmin()
        );
    }

    // Any signed-in user can write resolution fields — the allowlist is the security boundary.
    // Note: canReadBet() is deliberately NOT called here to avoid a cross-doc get() on a
    // document that may also be written in the same transaction commit (causes 403 in Firestore).
    function canResolveBet() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            'status',
            'resolution',
            'resolvedAt',
            'resolvedBy',
            'chanceSummary',
            'options',
            'predictionCount',
            'totalCoinsStaked',
            'updatedAt'
          ]);
    }

    function canApplyResolutionToUser() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['coinBalance', 'rating', 'rank', 'stats', 'updatedAt']);
    }

    function canApplyPredictionResult() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'correct', 'coinDelta', 'ratingDelta', 'resolvedAt', 'winningOptionId']);
    }

    function canEditBetMetadata() {
      return signedIn()
        && resource.data.creatorId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['title', 'description', 'category', 'deadline', 'imageUrl', 'updatedAt']);
    }

    match /usernames/{name} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(name));
      allow update: if false;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        (
          request.auth.uid == userId
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['displayName', 'photoURL', 'bio', 'username', 'updatedAt', 'lastRefillAt', 'coinBalance'])
        ) ||
        canApplyResolutionToUser()
      );
      allow delete: if false;
    }

    match /bets/{betId} {
      allow read: if canReadBet();
      allow create: if signedIn()
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if isAdmin() || canResolveBet() || canEditBetMetadata();
      allow delete: if signedIn() && resource.data.creatorId == request.auth.uid;
    }

    match /predictions/{predictionId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.stake >= 10;
      allow update: if canApplyPredictionResult();
      allow delete: if false;
    }

    match /chanceSnapshots/{snapshotId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /comments/{commentId} {
      allow read: if canReadBetById(resource.data.betId);
      allow create: if signedIn()
        && canReadBetById(request.resource.data.betId)
        && request.resource.data.keys().hasOnly([
          'betId',
          'userId',
          'username',
          'displayName',
          'photoURL',
          'body',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username == username()
        && request.resource.data.displayName == me().data.displayName
        && (
          (me().data.keys().hasAny(['photoURL']) && request.resource.data.photoURL == me().data.photoURL) ||
          (!me().data.keys().hasAny(['photoURL']) && request.resource.data.photoURL == null)
        )
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1000
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if false;
      allow delete: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    match /activity/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /adminConfig/{uid} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /friendGroups/{groupId} {
      allow read: if signedIn() && (
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.memberUids
      );
      allow create: if signedIn()
        && request.resource.data.creatorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.creatorId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['name', 'memberUsernames', 'memberUids', 'updatedAt']);
      allow delete: if signedIn()
        && resource.data.creatorId == request.auth.uid;
    }
  }
}
